<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" styleClass="page-container" xmlns:fx="http://javafx.com/fxml" fx:controller="com.toga.controller.FormUbahTanamanController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="Form Ubah Tanaman" styleClass="page-title"/>
    <VBox styleClass="card" spacing="12">
        <GridPane hgap="14" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>
            <Label text="Jenis" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="cmbJenis" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label text="Nama Tanaman" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <TextField fx:id="tfNama" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label text="Nama Latin" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="tfNamaLatin" styleClass="form-field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <Label fx:id="lblProperti" text="Properti" styleClass="form-label" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            <TextField fx:id="tfProperti" styleClass="form-field" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            <Label text="Tgl Tanam" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <DatePicker fx:id="dpTanggal" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Label text="Estimasi (hari)" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <TextField fx:id="tfEstimasiHari" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            <Label text="Manfaat" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextArea fx:id="taManfaat" prefHeight="50" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.columnSpan="3"/>
        </GridPane>
        <HBox spacing="10">
            <Button text="Simpan Ubah" onAction="#simpanUbah" styleClass="btn-primary"/>
            <Button text="Batal" onAction="#tutup" styleClass="btn-secondary"/>
        </HBox>
    </VBox>
</VBox>